{
  "name": "warden",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @warden/web",
    "dev:worker": "npm run dev -w @warden/worker",
    "build": "npm run build -w @warden/web",
    "start": "npm run start -w @warden/web",
    "lint": "npm run lint -w @warden/web",
    "db:generate": "npm run generate -w @warden/db",
    "db:migrate": "npm run migrate -w @warden/db",
    "db:migrate:deploy": "npm run migrate:deploy -w @warden/db",
    "db:seed": "npm run seed -w @warden/db"
  }
}
