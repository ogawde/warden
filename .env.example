DATABASE_URL="postgresql://postgres:postgres@localhost:5432/warden?schema=public"

# --- MVP (demo / worker) ---
GITLAB_PAT="glpat-xxxx"
GITLAB_PROJECT_ID="12345678"
GITLAB_BASE_URL="https://gitlab.com"
REPO_LOCAL_PATH="../demo/debt-lab"
WARDEN_MAX_FILE_LINES="400"
WORKER_URL="http://localhost:8080"
WORKER_SECRET="dev-worker-secret"
PORT="8080"
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
VERTEX_GEMINI_MODEL="gemini-2.5-flash"
AGENT_PLATFORM_REASONING_ENGINE_ID=""
AGENT_PLATFORM_CLASS_METHOD="query"

# Public app URL — used for GitLab OAuth redirect URI construction (Commit 7).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Phase 1 OAuth / Session (MVP v2) ---
# Auth mode: "demo" keeps seeded user + env GITLAB_PAT; "oauth" enables GitLab login (Commit 13).
WARDEN_AUTH_MODE="demo"

# GitLab OAuth application credentials (gitlab.com → User Settings → Applications).
# First consumed: Commit 7 (gitlab-oauth.ts).
GITLAB_OAUTH_CLIENT_ID=""
GITLAB_OAUTH_CLIENT_SECRET=""

# Space-separated GitLab OAuth scopes requested at authorize time.
# read_user: profile + gitlabUserId (Phase 1 login)
# read_api: list projects, MCP reads (Phase 2+)
# api: create issues on approve (Phase 3+)
# First consumed: Commit 7 (gitlab-oauth.ts).
GITLAB_OAUTH_SCOPES="read_user read_api api"

# Password for iron-session sealed cookie encryption. Min 32 chars; generate with: openssl rand -base64 32
# First consumed: Commit 6 (session.ts).
SESSION_SECRET=""

# AES-256-GCM key for encrypting GitLab access/refresh tokens at rest on User rows.
# 32-byte key, base64-encoded; generate with: openssl rand -base64 32
# First consumed: Commit 5 (token-crypto.ts).
TOKEN_ENCRYPTION_KEY=""
